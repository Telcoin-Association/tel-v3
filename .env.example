# ------------------
# RPC URLs — Mainnet
# ------------------

# Ethereum mainnet (required for fork tests and mainnet deployments)
ETHEREUM_RPC_URL=

# Base mainnet
BASE_RPC_URL=

# Polygon mainnet
POLYGON_RPC_URL=

# Telcoin Network (not yet active)
# TELCOIN_NETWORK_RPC_URL=

# ------------------
# RPC URLs — Testnet
# ------------------

# Ethereum Sepolia
ETH_SEPOLIA_RPC_URL=

# Base Sepolia
BASE_SEPOLIA_RPC_URL=

# ---------------
# Safe Deployment
# ---------------

# Address of the Gnosis Safe used as the deployer
DEPLOYER_SAFE_ADDRESS=

# EOA address of the signer submitting Safe transactions
SIGNER_ADDRESS=

# Additional signers for multi-sig threshold (optional, indexed from 0)
# SIGNER_ADDRESS_0=
# SIGNER_ADDRESS_1=
# SIGNER_ADDRESS_2=

# BIP-44 derivation path override (optional, for hardware wallets)
# DERIVATION_PATH=

# Hardware wallet type: "ledger" or "trezor" (default: ledger)
# HARDWARE_WALLET=

# Set to true to broadcast Safe transactions on-chain (default: false, simulates only)
# SAFE_BROADCAST=false

# ------------------------------
# Target chain filter (optional)
# ------------------------------

# Restrict multi-chain deployment scripts to a single chain by name
# CHAIN=
